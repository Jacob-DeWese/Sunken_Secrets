# =========================
# Unity Smart Merging
# =========================

*.unity merge=unityyamlmerge
*.prefab merge=unityyamlmerge
*.meta merge=unityyamlmerge

# =========================
# TextMesh Pro SDF Fonts (problem files)
# These regenerate frequently and should NOT be merged
# =========================

**/*SDF.asset merge=ours

# =========================
# Binary assets (no diffing / merging)
# =========================

*.bundle binary
*.fbx binary
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.mp3 binary
*.ogg binary
*.tga binary
